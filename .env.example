# Copy to .env (gitignored) and fill in. Used by `lune run test`.

# Open Cloud API key (create.roblox.com/dashboard/credentials) scoped to the
# test experience, with these permissions:
#   universe-places:write            (upload test place versions)
#   luau-execution-sessions:read
#   luau-execution-sessions:write
ROBLOX_API_KEY=

# The experience (universe) that owns the test place
ROBLOX_UNIVERSE_ID=

# A place inside that experience dedicated to test runs (never published live)
ROBLOX_PLACE_ID=
